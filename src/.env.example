# Copy this file to src/.env before running the application.
# Do not commit real API keys.

# LLM providers used by CV parsing and match scoring.
GROQ_API_KEY=
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
COHERE_API_KEY=
COHERE_API_KEY_1=
COHERE_API_KEY_2=
COHERE_API_KEY_3=
COHERE_API_KEY_4=
GEMINI_API_KEY=

# Location services.
GOONG_API_KEY=
GOOGLE_MAPS_API_KEY=

# Elasticsearch / service endpoints.
ES_HOST=http://localhost:9200
ES_INDEX=topcv_jobs_1300
OLLAMA_URL=http://localhost:11434/api/generate

# Retrieval/scoring switches.
# Production default from experiments: ESCO-only hybrid retrieval, city priority on.
ENABLE_SKILL_GRAPH=0
ENABLE_CITY_PRIORITY=1
LOCATION_SCORE_MODE=city

# LLM runtime tuning.
# Keep 70B for quality; reduce SCORING_TOP_N or switch to a lighter model if
# free-tier token-per-minute limits are hit during demos.
GROQ_PARSE_MODEL=llama-3.3-70b-versatile
GROQ_PARSE_MAX_COMPLETION_TOKENS=2000
CV_PARSE_PROVIDER=auto
COHERE_PARSE_MODEL=command-r-08-2024
COHERE_PARSE_MAX_TOKENS=1800
SCORING_PROVIDER=groq
GROQ_SCORING_MODEL=openai/gpt-oss-120b
GROQ_SCORING_MAX_COMPLETION_TOKENS=3000
COHERE_SCORING_MODEL=command-r-08-2024
COHERE_SCORING_MAX_TOKENS=2500
SCORING_TOP_N=30
SCORING_BATCH_WORKERS=4
